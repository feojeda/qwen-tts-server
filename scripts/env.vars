# Qwen3-TTS Server environment overrides
# Edit this file to customize model selection and behavior.
# After editing, redeploy: sudo bash scripts/deploy.sh

QWEN_TTS_HOST=0.0.0.0
QWEN_TTS_PORT=8000
QWEN_LAZY_TIMEOUT_SECONDS=300

# Model overrides (uncomment to override auto-detection):
